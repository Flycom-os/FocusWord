{
  "name": "FocusWord-Frontend",
  "version": "0.1.0",
  "private": true,
  "husky": {
    "hooks": {
      "pre-commit": "prettier --write .ts,.tsx,.js,.jsx . && git add ."
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "npx eslint ./**/*.{ts,tsx} --fix",
    "prettier": "prettier --write .ts,.tsx,.js,.jsx ",
    "storybook": "storybook dev -p 6006 --config-dir storybook",
    "build-storybook": "storybook build --config-dir storybook",
    "typecheck": "tsc --noEmit",
    "test": "jest --config config/jest/jest.config.ts",
    "test:unit": "jest --config config/jest/jest.config.ts"
  },
  "jest": {
    "testMatch": [
      "**/?(*.)+(test).[jt]sx"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "next": "^16.0.3",
    "next-themes": "^0.4.6",
    "react": "^19",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19",
    "react-hook-form": "^7.66.1",
    "react-input-mask": "^2.0.4",
    "react-toastify": "^11.0.5",
    "storybook": "^10.0.8",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@jest/globals": "^30.2.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.0.8",
    "@storybook/addon-onboarding": "^10.0.8",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^10.0.8",
    "@storybook/react": "^10.0.8",
    "@storybook/react-vite": "^10.0.8",
    "@storybook/test": "^8.6.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "16.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.2.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.0.8",
    "eslint-plugin-testing-library": "^7.13.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-recommended": "^17.0.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
